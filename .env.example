# Copy this file to .env.local and fill in your Plaid keys.
#   cp .env.example .env.local
#
# Get your keys at https://dashboard.plaid.com/developers/keys
#   - Start with PLAID_ENV=sandbox to try the app with fake test banks
#     (Plaid's sandbox login is username "user_good", password "pass_good").
#   - Switch to PLAID_ENV=production once you're ready to link your real banks.
#   - PLAID_SECRET must be the secret that matches PLAID_ENV.
#
# NOTE: after editing .env.local you must restart `npm run dev` —
# the app only reads these values when it starts up.

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Optional: where the local SQLite database file lives.
# Defaults to ./data/budgeting.db if unset.
# BUDGETING_DB_PATH=

# Optional: override the default local user id (advanced / multi-profile setups).
# Leave unset to run as the default single user.
# DEFAULT_USER_ID=

# Optional: set to "private" to enable CSV import, cross-source reconciliation,
# and one-time migration tooling. Defaults to the clean Plaid-first experience.
# NEXT_PUBLIC_APP_MODE=public
